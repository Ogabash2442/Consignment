{
  "entities": {
    "shipment": {
      "title": "Shipment",
      "description": "Information about a logistics parcel, cargo container, or freight shipment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "trackingId": { "type": "string" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "currentLocation": { "type": "string" },
        "weight": { "type": "number" },
        "shipmentType": { "type": "string" },
        "shipmentStatus": { "type": "string" },
        "estimatedDelivery": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "progress": { "type": "number" },
        "shippingCost": { "type": "number" },
        "carrierNote": { "type": "string" }
      },
      "required": ["id", "trackingId", "origin", "destination", "currentLocation", "weight", "shipmentType", "shipmentStatus", "estimatedDelivery", "createdAt", "updatedAt", "progress"]
    },
    "contact_message": {
      "title": "Contact Message",
      "description": "User inquiries submittable of contact form on the home or contact page",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "email", "subject", "message", "createdAt", "status"]
    },
    "admin_log": {
      "title": "Admin Activity Log",
      "description": "Chronological audit logs of administrative changes to shipments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "action": { "type": "string" },
        "trackingId": { "type": "string" },
        "details": { "type": "string" },
        "adminEmail": { "type": "string" }
      },
      "required": ["id", "timestamp", "action", "details", "adminEmail"]
    },
    "setting": {
      "title": "Portal Settings",
      "description": "Global enterprise configurations editable by the administrator",
      "type": "object",
      "properties": {
        "websiteName": { "type": "string" },
        "companyEmail": { "type": "string" },
        "companyPhone": { "type": "string" },
        "officeAddress": { "type": "string" },
        "supportHours": { "type": "string" }
      },
      "required": ["websiteName", "companyEmail", "companyPhone", "officeAddress", "supportHours"]
    },
    "chat": {
      "title": "Live Support Chat",
      "description": "Real-time support ticket conversation between client and carrier operators",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "messages": { "type": "array" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "status": { "type": "string" },
        "unreadCount": { "type": "number" },
        "lastMessage": { "type": "string" },
        "adminAssigned": { "type": "string" }
      },
      "required": ["chatId", "userName", "userEmail", "messages", "createdAt", "updatedAt", "status", "unreadCount", "lastMessage"]
    },
    "support_session": {
      "title": "Support Auditable Session",
      "description": "Log of active customer support helpline operations tracking compliance sessions",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "chatId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "startedAt": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["sessionId", "chatId", "userId", "userName", "userEmail", "startedAt", "status"]
    }
  },
  "firestore": {
    "shipments/{shipmentId}": {
      "schema": "shipment",
      "description": "Real-time query collection for tracking IDs and shipment parameters"
    },
    "contact_messages/{messageId}": {
      "schema": "contact_message",
      "description": "Administrative database for auditing consumer requests and support messages"
    },
    "admin_logs/{logId}": {
      "schema": "admin_log",
      "description": "Administrative log of creations, modifications, and deletions"
    },
    "settings/{settingId}": {
      "schema": "setting",
      "description": "Single-document mapping for general branding of the carrier website"
    },
    "chats/{chatId}": {
      "schema": "chat",
      "description": "Live real-time consumer conversations streams"
    },
    "support_sessions/{sessionId}": {
      "schema": "support_session",
      "description": "Administrative compliance sessions for quality assurance tracking"
    }
  }
}
