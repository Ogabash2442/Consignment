rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Chat sessions and their subcollections
    match /chats/{chatId} {
      // Allow read/write access to allow global visitor chats and real-time operator sync
      allow read, write: if true;

      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // Shipments collections for public tracking and admin updates
    match /shipments/{shipmentId} {
      allow read, write: if true;
    }

    // Customized corporate branding config doc 
    match /branding/{brandingId} {
      allow read, write: if true;
    }

    // Dynamic public homepage announcements
    match /announcements/{announcementId} {
      allow read, write: if true;
    }
  }
}
