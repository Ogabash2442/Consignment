rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == "myown2442@gmail.com");
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == "myown2442@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Guards ---
    function isValidShipment(data) {
      return data.trackingId is string && data.trackingId.size() <= 32 &&
             data.origin is string && data.origin.size() <= 128 &&
             data.destination is string && data.destination.size() <= 128 &&
             data.currentLocation is string && data.currentLocation.size() <= 128 &&
             data.weight is number && data.weight >= 0 && data.weight <= 100000 &&
             data.shipmentType is string && data.shipmentType.size() <= 64 &&
             data.shipmentStatus is string && data.shipmentStatus.size() <= 32 &&
             data.estimatedDelivery is string && data.estimatedDelivery.size() <= 32 &&
             data.progress is number && data.progress >= 0 && data.progress <= 100;
    }

    function isValidMessage(data) {
      return data.name is string && data.name.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.subject is string && data.subject.size() <= 256 &&
             data.message is string && data.message.size() <= 2048 &&
             data.status is string && (data.status == 'unread' || data.status == 'read' || data.status == 'replied');
    }

    // --- Collection Routes ---

    // 1. Shipments
    match /shipments/{shipmentId} {
      allow get: if isValidId(shipmentId); // Publicly trackable
      allow list: if isAdmin(); // Admin can search and view all shipments
      
      allow create: if isAdmin() && isValidId(shipmentId) && isValidShipment(incoming());
      
      allow update: if isAdmin() && isValidId(shipmentId) && isValidShipment(incoming());
      
      allow delete: if isAdmin() && isValidId(shipmentId);
    }

    // 2. Contact Messages
    match /contact_messages/{messageId} {
      allow get, list: if isAdmin();
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow update: if isAdmin() && isValidId(messageId) && isValidMessage(incoming());
      allow delete: if isAdmin() && isValidId(messageId);
    }

    // 3. Admin Activity Logs
    match /admin_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && isValidId(logId);
      allow update, delete: if false; // Immutable logs for audit security!
    }

    // 4. Portal Settings
    match /settings/{settingId} {
      allow get: if isValidId(settingId);
      allow list: if true; // Public list
      allow create, update: if isAdmin() && isValidId(settingId);
      allow delete: if isAdmin() && isValidId(settingId);
    }

    // 5. Admins Collection (roles)
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin() && isValidId(adminId);
    }

    // 6. Live Chats Support Ticketing
    match /chats/{chatId} {
      allow get: if isValidId(chatId);
      allow list: if isAdmin();
      allow create, update: if isValidId(chatId);
      allow delete: if isAdmin() && isValidId(chatId);
    }

    // 7. Support Audit Sessions Configuration
    match /support_sessions/{sessionId} {
      allow get: if isValidId(sessionId);
      allow list: if isAdmin();
      allow create, update: if isValidId(sessionId);
      allow delete: if isAdmin() && isValidId(sessionId);
    }

    // 8. Blocked Spam Users Config
    match /blocked_users/{email} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
